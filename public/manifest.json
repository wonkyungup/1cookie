{
  "name": "1Cookie",
  "manifest_version": 3,
  "version": "1.0.1",
  "permissions": [
    "tabs",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "description": "Cookie Management.",
  "icons": {
    "16": "16x16.png",
    "32": "32x32.png",
    "48": "48x48.png",
    "128": "128x128.png"
  },
  "action": {
    "default_icon": {
      "16": "16x16.png",
      "32": "32x32.png",
      "48": "48x48.png",
      "128": "128x128.png"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
