{
  "name": "1Cookie",
  "manifest_version": 2,
  "version": "1.0.0",
  "permissions": [
    "tabs",
    "cookies",
    "storage"
  ],
  "description": "Cookie data save and load",
  "icons": {
    "16": "16x16.png",
    "32": "32x32.png",
    "48": "48x48.png"
  },
  "browser_action": {
    "default_icon": {
      "16": "16x16.png"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "wonko93@naver.com"
    }
  }
}
